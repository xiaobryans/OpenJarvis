# Jarvis OMNIX Workbench Environment Configuration
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# Storage Configuration
OMNIX_WORKBENCH_STORAGE_PROVIDER=local
OMNIX_WORKBENCH_SOURCE_OF_TRUTH=local
OMNIX_WORKBENCH_AWS_REGION=ap-southeast-1
OMNIX_WORKBENCH_AWS_PROFILE=openclaw-admin
OMNIX_WORKBENCH_MEMORY_BUCKET=omnix-workbench-071179620006-ap-southeast-1-artifacts
OMNIX_WORKBENCH_ARTIFACT_BUCKET=omnix-workbench-071179620006-ap-southeast-1-artifacts
OMNIX_WORKBENCH_STATE_TABLE=omnix-workbench-071179620006-ap-southeast-1-state

# Cloud Node Configuration (jarvis omnix cloud detection)
OMNIX_WORKBENCH_CLOUD_STATUS_URL=http://100.118.81.37:3091

# Mission Control Configuration
OPENCLAW_WORKSPACE_DIR=/Users/user/CascadeProjects/openclaw-workspace-omnix
PORT=3091
HOST=127.0.0.1

# Slack Configuration
OPENCLAW_SLACK_CONTINUOUS_OPS_CHANNEL=C0BAF08SQTB
OPENCLAW_SLACK_BOT_TOKEN=xoxb-your-token-here

# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_DEFAULT_REGION=ap-southeast-1

# Tailscale Configuration (optional for Tailnet access)
TAILSCALE_AUTH_KEY=tskey-your-auth-key-here

# Telegram Configuration (Mega Sprint 2 — notification foundation)
# Set both to enable Telegram alerts from /v1/notify/telegram
JARVIS_TELEGRAM_BOT_TOKEN=
JARVIS_TELEGRAM_CHAT_ID=

# Voice Configuration (Voice Safety Sprint — Deepgram primary)
# Deepgram is the default/primary voice provider. Bryan has credits.
# Get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=
# Override provider selection (default: deepgram for all)
# JARVIS_VOICE_PROVIDER=deepgram
# JARVIS_STT_PROVIDER=deepgram
# JARVIS_TTS_PROVIDER=deepgram
# JARVIS_STT_MODEL=nova-2
# JARVIS_TTS_MODEL=aura-asteria-en
# JARVIS_VOICE_LANGUAGE=en
# Voice recording / silence endpointing (safe defaults shown)
# Normal turn end: silence-based. JARVIS_VOICE_MAX_RECORD_SECONDS is emergency-only.
# JARVIS_VOICE_MIN_RECORD_SECONDS=1.0
# JARVIS_VOICE_SILENCE_STOP_MS=4000
# JARVIS_VOICE_MAX_RECORD_SECONDS=120
# JARVIS_VOICE_SILENCE_RMS=150

# MacBook-off cloud runtime URL (optional)
# Set this on the local server so /v1/mobile/continuity/status can advertise
# the cloud backend URL to mobile clients (used for cloud_url field).
# JARVIS_CLOUD_URL=https://2r8dnzlz1h.execute-api.ap-southeast-1.amazonaws.com
