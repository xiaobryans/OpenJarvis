# AWS Cloud Deployment Environment Variables Example
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# Storage Configuration
OMNIX_WORKBENCH_STORAGE_PROVIDER=aws
OMNIX_WORKBENCH_SOURCE_OF_TRUTH=cloud
OMNIX_WORKBENCH_AWS_REGION=ap-southeast-1
OMNIX_WORKBENCH_AWS_PROFILE=openclaw-admin
OMNIX_WORKBENCH_MEMORY_BUCKET=omnix-workbench-artifacts-071179620006-ap-southeast-1
OMNIX_WORKBENCH_ARTIFACT_BUCKET=omnix-workbench-artifacts-071179620006-ap-southeast-1
OMNIX_WORKBENCH_STATE_TABLE=omnix-workbench-state

# Mission Control Configuration
OPENCLAW_WORKSPACE_DIR=/app/openclaw-workspace
PORT=3091
HOST=0.0.0.0

# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_DEFAULT_REGION=ap-southeast-1

# Slack Configuration (optional)
# OPENCLAW_SLACK_CONTINUOUS_OPS_CHANNEL=C0BAF08SQTB
# OPENCLAW_SLACK_BOT_TOKEN=xoxb-your-token-here

# Tailscale Configuration (optional for Tailnet access)
# TAILSCALE_AUTH_KEY=tskey-your-auth-key-here

# Additional Environment Variables
# Add any additional required environment variables here
